{
  "permissions": {
    "allow": [
      "Read",
      "Edit(api/**)",
      "Write(api/**)",
      "Edit(docs/**)",
      "Edit(*.html)",
      "Edit(site.css)",
      "Edit(favicon.svg)",
      "Edit(*.js)",
      "Bash(npm run check:*)",
      "Bash(npm test:*)",
      "Bash(npm run test:*)",
      "Bash(npm run smoke:*)",
      "Bash(npm run lint:*)",
      "Bash(npm run typecheck:*)",
      "Bash(npm run dev:*)",
      "Bash(npm run migrate:*)",
      "Bash(npm ci:*)",
      "Bash(npm install:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git add:*)",
      "Bash(git switch:*)",
      "Bash(git checkout:*)",
      "Bash(git branch:*)"
    ],
    "deny": [
      "Bash(rm -rf:*)",
      "Bash(git push --force:*)",
      "Bash(git push -f:*)"
    ],
    "ask": [
      "Bash(git push:*)",
      "Bash(gh pr create:*)",
      "Bash(gh pr merge:*)"
    ]
  }
}
